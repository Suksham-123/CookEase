<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/imageView_instructions_step_items"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="8dp"
        android:contentDescription="Equipment Image"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_launcher_background" /> <!-- default image -->

    <TextView
        android:id="@+id/textView_instructions_step_items"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Equipment Name"
        android:textSize="14sp"
        android:textColor="@android:color/black" />
</LinearLayout>
